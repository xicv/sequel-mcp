{
  "name": "sequel-ace-mcp",
  "version": "0.1.0",
  "description": "MCP server that lets Claude run MySQL/MariaDB queries via Sequel Ace's saved connections, with policy-gated read/write/DDL action sets and macOS Keychain credential storage.",
  "type": "module",
  "bin": {
    "sequel-ace-mcp": "./dist/index.js",
    "sequel-ace-mcp-doctor": "./dist/doctor.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:touchid": "swiftc scripts/touchid-helper.swift -o dist/touchid-helper",
    "dev": "tsc -w -p tsconfig.json",
    "start": "node dist/index.js",
    "doctor": "node dist/doctor.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "security:scan": "bash scripts/check-secrets.sh",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "mysql2": "^3.11.5",
    "node-sql-parser": "^5.3.4",
    "plist": "^3.1.0",
    "ssh2": "^1.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/plist": "^3.0.5",
    "@types/ssh2": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
